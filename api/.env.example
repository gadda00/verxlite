# ------------------------------------------------------------------
# Verxlite API — environment template
# Copy to `api/.env` and fill in real values.
# ------------------------------------------------------------------

# Environment
ENVIRONMENT=development
DEBUG=false

# Database (SQLite for dev; PostgreSQL for prod)
DATABASE_URL=sqlite:///./verxlite.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verxlite

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend URL (for OAuth redirects & CORS)
FRONTEND_URL=http://localhost:3000

# Auth — Clerk (optional in dev; if unset, local JWT auth is used)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# JWT (used when CLERK_SECRET_KEY is not set)
JWT_SECRET=change-me-to-a-32-byte-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/connections/google/callback

# OAuth — HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/connections/hubspot/callback

# LLM Providers (optional — engine falls back to a deterministic mock if unset)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Observability — Langfuse (optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Encryption — REQUIRED in production. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset in dev, one is derived deterministically from JWT_SECRET.
ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
